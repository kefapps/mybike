{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "minimax-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "MiniMax M3 via Anthropic API",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}",
        "setCacheKey": true,
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax-M3",
          "limit": {
            "context": 512000,
            "output": 64000
          }
        }
      }
    }
  },
  "model": "minimax-anthropic/MiniMax-M3",
  "small_model": "minimax-anthropic/MiniMax-M3",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "_bmad-output/**",
      "playwright-report/**",
      "test-results/**",
      "blob-report/**"
    ]
  }
}